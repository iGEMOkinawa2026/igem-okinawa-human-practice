---
import type { CollectionEntry } from 'astro:content';
import type { SiteLocale } from '../data/homeCopy';
import { withBase } from '../lib/paths';

interface Props {
  locale: SiteLocale;
  sectionTitle: string;
  subtitle: string;
  activities: CollectionEntry<'activities'>[];
}

const { locale, sectionTitle, subtitle, activities } = Astro.props;

function imageSrc(image?: string) {
  if (!image) return null;
  if (image.startsWith('http://') || image.startsWith('https://')) return image;
  const path = image.startsWith('/') ? image.slice(1) : image;
  return withBase(path);
}

function titleFor(entry: CollectionEntry<'activities'>) {
  if (locale === 'ja' && entry.data.title_ja) return entry.data.title_ja;
  return entry.data.title;
}

function descriptionFor(entry: CollectionEntry<'activities'>) {
  if (locale === 'ja' && entry.data.description_ja) return entry.data.description_ja;
  return entry.data.description;
}

function dateFor(entry: CollectionEntry<'activities'>) {
  if (locale === 'ja' && entry.data.date_ja) return entry.data.date_ja;
  return entry.data.date;
}

function detailFor(entry: CollectionEntry<'activities'>) {
  if (locale === 'ja' && entry.data.detail_ja) return entry.data.detail_ja;
  return entry.data.detail ?? descriptionFor(entry);
}

function placeholderFor(entry: CollectionEntry<'activities'>) {
  if (locale === 'ja' && entry.data.imagePlaceholder_ja) return entry.data.imagePlaceholder_ja;
  return entry.data.imagePlaceholder ?? '[ Project Image ]';
}
---

<section id="activities" class="activities section-alt">
  <div class="container">
    <div class="section-header">
      <h2>{sectionTitle}</h2>
      <p class="subtitle">{subtitle}</p>
    </div>
    <div class="activity-cards">
      {
        activities.map((item, idx) => {
          const img = imageSrc(item.data.image);
          const placeholder = placeholderFor(item);
          const title = titleFor(item);
          const description = descriptionFor(item);
          const dateLabel = dateFor(item);
          const detail = detailFor(item);
          const dialogId = `activity-modal-${locale}-${idx}`;
          return (
            <article class="card activity-card">
              {img ? (
                <div class="card-image">
                  <img src={img} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="card-img-placeholder">{placeholder}</div>
              )}
              <div class="card-content">
                {dateLabel && <p class="activity-date">{dateLabel}</p>}
                <h3>{title}</h3>
                <p>{description}</p>
                <button class="activity-more" type="button" data-activity-open={dialogId}>
                  {locale === 'ja' ? '詳細を見る' : 'View details'}
                </button>
              </div>

              <dialog id={dialogId} class="activity-modal">
                <div class="activity-modal-head">
                  {dateLabel && <p class="activity-date">{dateLabel}</p>}
                  <h3>{title}</h3>
                </div>
                <p>{detail}</p>
                <form method="dialog" class="activity-modal-actions">
                  <button type="submit" class="btn btn-outline-dark">
                    {locale === 'ja' ? '閉じる' : 'Close'}
                  </button>
                </form>
              </dialog>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const trigger = target.closest('[data-activity-open]');
    if (!(trigger instanceof HTMLElement)) return;
    const id = trigger.getAttribute('data-activity-open');
    if (!id) return;
    const dialog = document.getElementById(id);
    if (dialog instanceof HTMLDialogElement) {
      dialog.showModal();
    }
  });
</script>
