---
interface NavItem {
  label: string;
  href: string;
  children?: NavItem[];
}

interface Props {
  siteTitle: string;
  logoHref: string;
  navItems: NavItem[];
  enHref: string;
  jaHref: string;
  activeLang: 'en' | 'ja';
  langEnLabel?: string;
  langJpLabel?: string;
  menuToggleLabel?: string;
}

const {
  siteTitle,
  logoHref,
  navItems,
  enHref,
  jaHref,
  activeLang,
  langEnLabel = 'EN',
  langJpLabel = 'JP',
  menuToggleLabel = 'Toggle navigation',
} = Astro.props;
---

<header class="site-header">
  <div class="header-container">
    <div class="logo">
      <a href={logoHref}>{siteTitle}</a>
    </div>

    <button
      id="mobile-menu-toggle"
      class="mobile-menu-toggle"
      type="button"
      aria-expanded="false"
      aria-label={menuToggleLabel}
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <nav id="main-nav" class="main-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li class:list={[{ 'has-dropdown': item.children && item.children.length > 0 }]}>
            <a href={item.href}>{item.label}</a>
            {item.children && item.children.length > 0 && (
              <ul class="dropdown-menu">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <div class="lang-switcher">
        <a
          href={enHref}
          class:list={['lang-btn', { active: activeLang === 'en' }]}
          aria-current={activeLang === 'en' ? 'page' : undefined}
          >{langEnLabel}</a
        >
        <span class="lang-sep">/</span>
        <a
          href={jaHref}
          class:list={['lang-btn', { active: activeLang === 'ja' }]}
          aria-current={activeLang === 'ja' ? 'page' : undefined}
          >{langJpLabel}</a
        >
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mainNav = document.getElementById('main-nav');

    if (menuToggle && mainNav) {
      menuToggle.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!isExpanded));
        mainNav.classList.toggle('nav-open');
      });
    }
  });
</script>
