---
import type { CollectionEntry } from 'astro:content';
import type { SiteLocale } from '../data/homeCopy';
import { withBase } from '../lib/paths';

interface Props {
  locale: SiteLocale;
  title: string;
  body: string;
  sponsorCtaHref: string;
  sponsorCtaLabel: string;
  deckHref: string;
  deckLabel: string;
  sponsors: CollectionEntry<'sponsors'>[];
}

const { locale, title, body, sponsorCtaHref, sponsorCtaLabel, deckHref, deckLabel, sponsors } =
  Astro.props;

const tierLabelEn: Record<string, string> = {
  gold: 'Gold',
  silver: 'Silver',
  bronze: 'Bronze',
  partner: 'Partner',
};

const tierLabelJa: Record<string, string> = {
  gold: 'ゴールド',
  silver: 'シルバー',
  bronze: 'ブロンズ',
  partner: 'パートナー',
};

const tierLabel = locale === 'ja' ? tierLabelJa : tierLabelEn;

function logoSrc(logo?: string) {
  if (!logo) return null;
  if (logo.startsWith('http://') || logo.startsWith('https://')) return logo;
  const path = logo.startsWith('/') ? logo.slice(1) : logo;
  return withBase(path);
}

function sponsorName(entry: CollectionEntry<'sponsors'>) {
  if (locale === 'ja' && entry.data.name_ja) return entry.data.name_ja;
  return entry.data.name;
}
---

<section id="support" class="support section">
  <div class="support-bg"></div>
  <div class="container support-content text-center">
    <h2>{title}</h2>
    <p>{body}</p>
    {
      sponsors.length > 0 && (
        <div class="sponsor-logos" aria-label={locale === 'ja' ? 'スポンサー' : 'Sponsors'}>
          {sponsors.map((s) => {
            const src = logoSrc(s.data.logo);
            const name = sponsorName(s);
            const tierKey = s.data.tier;
            const tierText = tierLabel[tierKey] ?? tierKey;
            const tierLine =
              locale === 'ja' ? `${tierText}スポンサー` : `${tierText} sponsor`;
            return (
              <div class="sponsor-item">
                {src ? (
                  <img src={src} alt={name} loading="lazy" />
                ) : (
                  <span class="sponsor-name-fallback">{name}</span>
                )}
                <span class="sponsor-tier">{tierLine}</span>
              </div>
            );
          })}
        </div>
      )
    }
    <div class="sponsor-actions">
      <a href={sponsorCtaHref} class="btn btn-primary btn-large">{sponsorCtaLabel}</a>
      <a href={deckHref} class="btn btn-outline-white btn-large">{deckLabel}</a>
    </div>
  </div>
</section>
