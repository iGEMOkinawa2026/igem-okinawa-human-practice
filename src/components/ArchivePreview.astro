---
import type { CollectionEntry } from 'astro:content';
import type { SiteLocale } from '../data/homeCopy';
import { withBase } from '../lib/paths';

interface Props {
  locale: SiteLocale;
  title: string;
  body: string;
  archiveButtonLabel: string;
  entries: CollectionEntry<'archive'>[];
}

const { locale, title, body, archiveButtonLabel, entries } = Astro.props;

const resolvedArchiveHref =
  locale === 'ja' ? withBase('ja/archive/') : withBase('archive/');
const resolvedArchiveLabel =
  locale === 'ja' ? 'アーカイブを見る' : archiveButtonLabel;

function entryTitle(e: CollectionEntry<'archive'>) {
  if (locale === 'ja' && e.data.title_ja) return e.data.title_ja;
  return e.data.title;
}

function entrySummary(e: CollectionEntry<'archive'>) {
  if (locale === 'ja' && e.data.summary_ja) return e.data.summary_ja;
  return e.data.summary;
}
---

<section id="archive" class="archive-preview section-alt">
  <div class="container archive-container">
    <div class="archive-main">
      <div class="archive-text">
        <h2>{title}</h2>
        <p>{body}</p>
      </div>
      {
        entries.length > 0 && (
          <div class="archive-entries">
            {entries.map((e) => (
              <article class="archive-entry">
                <div class="archive-entry-year">{e.data.year}</div>
                <h3>{entryTitle(e)}</h3>
                <p class="archive-entry-summary">{entrySummary(e)}</p>
              </article>
            ))}
          </div>
        )
      }
    </div>
    <div class="archive-action">
      <a href={resolvedArchiveHref} class="btn btn-outline-dark">{resolvedArchiveLabel}</a>
    </div>
  </div>
</section>
