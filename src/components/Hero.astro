---
interface Props {
  badgeText: string;
  /** When true, badge avoids all-caps styling (better for Japanese). */
  badgeNatural?: boolean;
  headingPrefix: string;
  headingStrong: string;
  headingSuffix: string;
  headingSuffixSmall?: boolean;
  lede: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  secondaryCtaLabel: string;
  secondaryCtaHref: string;
  imagePlaceholderText: string;
}
const {
  badgeText,
  badgeNatural = false,
  headingPrefix,
  headingStrong,
  headingSuffix,
  headingSuffixSmall = false,
  lede,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  imagePlaceholderText,
} = Astro.props;

const badgeClass = badgeNatural ? 'badge badge--natural' : 'badge';
---

<section class="hero">
  <div class="hero-bg-accent"></div>
  <div class="container hero-content">
    <div class="hero-text">
      <span class={badgeClass}>{badgeText}</span>
      <h1>
        {headingPrefix}<strong>{headingStrong}</strong><span class:list={['hero-heading-suffix', { 'hero-heading-suffix--small': headingSuffixSmall }]}>{headingSuffix}</span>
      </h1>
      <p>{lede}</p>
      <div class="hero-actions">
        <a href={primaryCtaHref} class="btn btn-primary">{primaryCtaLabel}</a>
        <a href={secondaryCtaHref} class="btn btn-secondary">{secondaryCtaLabel}</a>
      </div>
    </div>
    <div class="hero-image-wrapper">
      <div class="hero-image-placeholder">
        <span class="placeholder-text">{imagePlaceholderText}</span>
      </div>
      <div class="decoration-dots"></div>
    </div>
  </div>
</section>
