---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import { withBase } from '../../../lib/paths';

const newsEntries = (await getCollection('news')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<PageLayout
  title="ニュース | iGEM Okinawa"
  description="iGEM Okinawaからの最新のニュースと更新情報。"
  locale="ja"
>
  <PageHero
    title="ニュース"
    subtitle="最新の活動やチームからのお知らせ。"
    breadcrumbs={[{ label: 'ホーム', href: withBase('ja/') }]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="news-grid">
        {newsEntries.map((post) => (
          <article class="card news-card">
            {post.data.image ? (
              <div class="card-image">
                <a href={withBase(`ja/news/${post.slug}/`)}>
                  <img src={withBase(post.data.image)} alt={post.data.title} loading="lazy" />
                </a>
              </div>
            ) : (
              <div class="card-img-placeholder">
                <a href={withBase(`ja/news/${post.slug}/`)} style="color: inherit; text-decoration: none;">
                  [ News Image ]
                </a>
              </div>
            )}
            <div class="card-content">
              <p class="news-date">{post.data.date}</p>
              <h3><a href={withBase(`ja/news/${post.slug}/`)}>{post.data.title}</a></h3>
              {post.data.summary && <p class="news-summary">{post.data.summary}</p>}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="news-tags">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .news-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 1280px) {
    .news-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .card-img-placeholder {
    width: 100%;
    height: 200px;
    background-color: #E2E8F0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }
  .news-date {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
  }
  .news-card h3 {
    margin-bottom: 0.5rem;
  }
  .news-card h3 a {
    color: var(--color-primary);
  }
  .news-card h3 a:hover {
    color: var(--color-secondary);
  }
  .news-summary {
    margin-top: 0.5rem;
    color: var(--color-text-main);
  }
  .news-tags {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.75rem;
    background: var(--color-bg-base);
    border: 1px solid rgba(0,0,0,0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    color: var(--color-text-muted);
  }
</style>
