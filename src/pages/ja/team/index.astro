---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { siteCopy } from '../../../data/siteCopy';
import { getMainNav } from '../../../data/navigation';
import { withBase } from '../../../lib/paths';
import YAML from 'yaml';
import socialRaw from '../../../data/social.yaml?raw';

const members = (await getCollection('members')).sort((a, b) => a.data.order - b.data.order);
const wetTeam = members.filter(m => m.data.team === 'wet');
const dryTeam = members.filter(m => m.data.team === 'dry');
const hpTeam = members.filter(m => m.data.team === 'human practice');
const fundingTeam = members.filter(m => m.data.team === 'funding');
const wikiTeam = members.filter(m => m.data.team === 'wiki-video');

const social = YAML.parse(socialRaw) as any;
const copy = siteCopy.ja;
const navItems = getMainNav('ja');
const footerLinks = navItems.map(i => ({ label: i.label, href: i.href }));
---

<BaseLayout title={`チーム - ${copy.page.title}`} description="iGEM Okinawa チームメンバー" lang="ja">
  <Header
    siteTitle={copy.header.siteTitle}
    logoHref={withBase('ja/')}
    navItems={navItems}
    enHref={withBase('team/')}
    jaHref={withBase('ja/team/')}
    activeLang="ja"
    menuToggleLabel={copy.header.menuToggleLabel}
  />
  <main class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <h1 style="color: var(--color-primary);">チームについて</h1>
        <p class="subtitle">沖縄の様々な機関から集まった合同チームです。</p>
      </div>

      {[ 
        { title: 'ウェットラボ (Wet Lab)', members: wetTeam, color: '#dbeafe', text: '#1e40af' },
        { title: 'ドライラボ (Dry Lab)', members: dryTeam, color: '#dcfce7', text: '#166534' },
        { title: 'ヒューマンプラクティス (Human Practice)', members: hpTeam, color: '#fef9c3', text: '#854d0e' },
        { title: 'ファンディング (Funding)', members: fundingTeam, color: '#fce7f3', text: '#9d174d' },
        { title: 'Wiki / Video', members: wikiTeam, color: '#ede9fe', text: '#5b21b6' }
      ].map(group => group.members.length > 0 && (
        <div style="margin-bottom: 4rem;">
          <h2 style={`display: inline-block; padding: 0.5rem 1rem; border-radius: var(--border-radius-md); background: ${group.color}; color: ${group.text}; margin-bottom: 1.5rem;`}>
            {group.title}
          </h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem;">
            {group.members.map(member => (
              <div class="card" style="padding: 1.5rem; text-align: center; background: white; border-radius: var(--border-radius-lg); box-shadow: var(--shadow-sm);">
                <div style="width: 100px; height: 100px; border-radius: 50%; background: var(--color-bg-alt); margin: 0 auto 1rem; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                  {member.data.image ? (
                    <img src={withBase(member.data.image)} alt={member.data.name_ja || member.data.name} style="width: 100%; height: 100%; object-fit: cover;" />
                  ) : (
                    <span style="font-size: 2rem; color: var(--color-text-muted);">👤</span>
                  )}
                </div>
                <h3 style="margin-bottom: 0.5rem; color: var(--color-text-heading);">{member.data.name_ja || member.data.name}</h3>
                <p style="font-weight: 600; color: var(--color-primary); font-size: 0.9rem; margin-bottom: 0.5rem;">{member.data.role_ja || member.data.role}</p>
                {(member.data.institution_ja || member.data.institution) && <p style="font-size: 0.85rem; color: var(--color-text-main); margin-bottom: 0;">{member.data.institution_ja || member.data.institution}</p>}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer brandTitle={copy.footer.brandTitle} brandTagline={copy.footer.brandTagline} exploreHeading={copy.footer.exploreHeading} exploreLinks={footerLinks} connectHeading={copy.footer.connectHeading} copyrightLine={copy.footer.copyrightLine} privacyHref={copy.footer.privacyHref} privacyLabel={copy.footer.privacyLabel} termsHref={copy.footer.termsHref} termsLabel={copy.footer.termsLabel} socialLinks={social.links} />
</BaseLayout>
