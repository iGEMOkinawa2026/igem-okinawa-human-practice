---
/**
 * Portal Landing Page (JA)
 */
import YAML from 'yaml';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MemberCard from '../../components/MemberCard.astro';

import { siteCopy } from '../../data/siteCopy';
import { getMainNav } from '../../data/navigation';
import { withBase } from '../../lib/paths';

import socialRaw from '../../data/social.yaml?raw';

const social = YAML.parse(socialRaw) as {
  links: { platform: string; url: string; shortLabel?: string }[];
};

const copy = siteCopy.ja;
const navItems = getMainNav('ja');

const footerLinks = navItems.map((item) => ({
  label: item.label,
  href: item.href,
}));

// Mock data for Team Preview
const teamMembers = [
  { name: 'Alice Smith', role: ['Leader', 'Wet Lab'], description: 'プロジェクト全体を統括し、ウェットラボでの実験を推進。' },
  { name: 'Bob Jones', role: ['Dry Lab', 'Wiki'], description: 'モデリングとWebサイト（Wiki）開発を担当。' },
  { name: 'Charlie Doe', role: ['Human Practice'], description: '地域社会との連携、ステークホルダーからのフィードバック収集。' }
];
---

<BaseLayout title={`ポータル - ${copy.page.title}`} description="iGEM Okinawa チームポータルへようこそ" lang="ja">
  <Header
    siteTitle={copy.header.siteTitle}
    logoHref={withBase('ja/')}
    navItems={navItems}
    enHref={withBase('')}
    jaHref={withBase('ja/')}
    activeLang="ja"
    menuToggleLabel={copy.header.menuToggleLabel}
  />

  <main>
    <!-- Hero Section -->
    <section class="portal-hero">
      <div class="container text-center">
        <h1 class="portal-hero-title">iGEM <strong>Okinawa</strong></h1>
        <p class="portal-hero-slogan">合成生物学で、琉球列島の持続可能な未来をデザインする。</p>
        <div class="portal-hero-actions">
          <a href="#about" class="btn btn-primary btn-large">私たちの使命</a>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="section section-alt">
      <div class="container">
        <div class="section-header text-center">
          <h2>About Us</h2>
          <p class="subtitle">Mission & Vision</p>
        </div>
        <div class="mission-grid">
          <div class="mission-card">
            <div class="icon">🌊</div>
            <h3>Local Innovation</h3>
            <p>合成生物学を用いて、沖縄の海洋や陸上生態系における固有の課題を解決します。</p>
          </div>
          <div class="mission-card">
            <div class="icon">🤝</div>
            <h3>Community Engagement</h3>
            <p>地域のステークホルダーや農家、産業界と密接に連携し、社会実装を目指します。</p>
          </div>
          <div class="mission-card">
            <div class="icon">🔬</div>
            <h3>Scientific Excellence</h3>
            <p>厳密な手法とオープンサイエンスを通じて、次世代の研究者を育成します。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Project Preview -->
    <section class="section">
      <div class="container">
        <div class="project-preview-container">
          <div class="project-preview-text">
            <h2>Current Project: 2026</h2>
            <p>亜熱帯気候における農業のレジリエンス（回復力）を高める革新的なアプローチに取り組んでいます。環境への影響を最小限に抑えつつ、重要な農作物を保護するシステムの構築を目指します。</p>
            <a href={withBase('ja/project/2026/')} class="btn btn-primary">2026年プロジェクトを見る</a>
          </div>
          <div class="project-preview-visual">
            <div class="dna-graphic-placeholder">
              [ 2026 Project Graphic ]
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Preview -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-header text-center">
          <h2>Our Team</h2>
          <p class="subtitle">iGEM Okinawaのメンバー紹介</p>
        </div>
        <div class="team-grid">
          {teamMembers.map(member => (
            <MemberCard name={member.name} role={member.role} description={member.description} />
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer
    brandTitle={copy.footer.brandTitle}
    brandTagline={copy.footer.brandTagline}
    exploreHeading={copy.footer.exploreHeading}
    exploreLinks={footerLinks}
    connectHeading={copy.footer.connectHeading}
    copyrightLine={copy.footer.copyrightLine}
    privacyHref={copy.footer.privacyHref}
    privacyLabel={copy.footer.privacyLabel}
    termsHref={copy.footer.termsHref}
    termsLabel={copy.footer.termsLabel}
    socialLinks={social.links}
  />
</BaseLayout>

<style>
  .portal-hero {
    padding: 8rem 1rem;
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, var(--color-bg-base) 100%);
    position: relative;
    overflow: hidden;
  }
  .portal-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 80%;
    height: 200%;
    background: radial-gradient(circle, rgba(66, 87, 166, 0.05) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
  }
  .portal-hero .container {
    position: relative;
    z-index: 1;
  }
  .portal-hero-title {
    font-size: clamp(3rem, 2rem + 4vw, 5rem);
    color: var(--color-text-heading);
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }
  .portal-hero-title strong {
    color: var(--color-primary);
  }
  .portal-hero-slogan {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 3rem;
  }
  .project-preview-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
    background: var(--color-bg-base);
    padding: 3rem;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0,0,0,0.03);
  }
  @media (min-width: 768px) {
    .project-preview-container {
      grid-template-columns: 1fr 1fr;
    }
  }
  .project-preview-text h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .project-preview-text p {
    font-size: 1.125rem;
    margin-bottom: 2rem;
    color: var(--color-text-main);
  }
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
