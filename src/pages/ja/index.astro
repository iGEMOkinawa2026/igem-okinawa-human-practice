---
/**
 * Portal Landing Page (JA)
 */
import YAML from 'yaml';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import { siteCopy } from '../../data/siteCopy';
import { getMainNav } from '../../data/navigation';
import { withBase } from '../../lib/paths';

import socialRaw from '../../data/social.yaml?raw';

const social = YAML.parse(socialRaw) as {
  links: { platform: string; url: string; shortLabel?: string }[];
};

const copy = siteCopy.ja;
const navItems = getMainNav('ja');

const footerLinks = navItems.map((item) => ({
  label: item.label,
  href: item.href,
}));


---

<BaseLayout title={`ポータル - ${copy.page.title}`} description="iGEM Okinawa チームポータルへようこそ" lang="ja">
  <Header
    siteTitle={copy.header.siteTitle}
    logoHref={withBase('ja/')}
    navItems={navItems}
    enHref={withBase('')}
    jaHref={withBase('ja/')}
    activeLang="ja"
    menuToggleLabel={copy.header.menuToggleLabel}
  />

  <main>
    <!-- Hero Section -->
    <section class="portal-hero">
      <div class="container text-center">
        <h1 class="portal-hero-title">iGEM <strong>Okinawa</strong></h1>
        <p class="portal-hero-slogan">合成生物学で未来を創造する</p>
        <div class="portal-hero-actions">
          <a href="#about" class="btn btn-primary btn-large">私たちの使命</a>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="section section-alt">
        <div class="container">
          <div class="section-header text-center">
            <h2>iGEM Okinawa について</h2>
            <p class="subtitle">私たちについて</p>
          </div>
          <div class="mission-grid">
            <!-- card1: 実績 -->
            <div class="mission-card">
              <div class="icon">🏆</div>
              <h3>2025 ゴールドメダル</h3>
              <p>iGEMへ初出場した2025年、iGEM Okinawa はゴールドメダルを獲得しました。これは、チームが厳格な科学への取り組みと地域社会への貢献に尽力してきた証です。</p>
            </div>
            <!-- card2: チーム構成 -->
            <div class="mission-card">
              <div class="icon">🏫</div>
              <h3>県内複数校の合同チーム</h3>
              <p>OIST、沖縄高専、琉球大学の学生が集まり、ウェットラボ、ドライラボ、そしてヒューマンプラクティスなどの各分野における多様な専門知識を結集しています。</p>
            </div>
            <!-- card3: 地域課題 -->
            <div class="mission-card">
              <div class="icon">🌾</div>
              <h3>地域特有の課題、確かな成果</h3>
              <p>私たちのプロジェクトは、沖縄ならではの環境に根ざしています。地元の農家や地域社会と直接連携し、合成生物学によるソリューションが、現実的で差し迫ったニーズに応えられるよう取り組んでいます。</p>
            </div>

          </div>
        </div>
      </section>

    <!-- Project Preview -->
    <section class="section">
      <div class="container">
        <div class="project-preview-container">
          <div class="project-preview-text">
            <h2>最新の取り組み: 2026</h2>
            <p class="project-preview-tag">AI × Biology</p>
            <p>
              私たちは、<strong>低pH耐性バクテリオファージ</strong>
              を開発し、人々の健康と沖縄の農業産業に甚大な被害をもたらしている
              AMR病原体（サルモネラ菌、ETEC、ピロリ菌）と戦っています。
              AIを活用したパイプラインを用いて、胃の酸性環境下で
              効果を発揮するファージタンパク質の変異体を予測・検証しています。
            </p>
            <a href={withBase('project/2026/')} class="btn btn-primary">続きを読む</a>
          </div>
          <div class="project-preview-visual">
            <!-- EDIT: 画像が用意できたら img タグに差し替える -->
            <div class="dna-graphic-placeholder">
              🦠 Phage × AI
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Preview -->
    <!-- EDIT: チーム説明文・メンバー数はここを直接編集 -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-header text-center">
          <h2>チームについて</h2>
          <p class="subtitle">
            OIST、沖縄高専、琉球大学の学生たちが集まり、活動しています。
          </p>
        </div>

        <div class="team-blocks">

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag wet">Wet Lab</span>
              <h3>ウェットラボ</h3>
            </div>
            <p>すべての実験業務（ファージの単離、タンパク質工学、クローニング、およびAIが予測した変異体の実験室での検証）を担当します。</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag dry">Dry Lab</span>
              <h3>ドライラボ</h3>
            </div>
            <p>低pH耐性ファージタンパク質変異体の予測を行うAIベースのパイプラインを構築・運用する。計算モデリングおよびデータ分析を担当する。</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag hp">Human Practice</span>
              <h3>ヒューマンプラクティス</h3>
            </div>
            <p>私たちの科学を社会と結びつける――地元の農家、医療従事者、地域社会と連携し、私たちの活動が真のニーズに応えるよう努めています。</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag funding">Funding</span>
              <h3>ファンディング</h3>
            </div>
            <p>研究活動および国際大会への参加を維持するため、スポンサー開拓、寄付キャンペーン、および財務計画の管理を行っています。</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag wiki">Wiki / Video</span>
              <h3>Wiki / Video</h3>
            </div>
            <p>iGEM Wiki、プロモーション動画、そしてこのウェブサイトを通じて、私たちの研究成果を記録・発信し、世界中の人々が私たちの活動にアクセスできるようにしています。</p>
          </div>

        </div>

        <div class="text-center" style="margin-top: 3rem;">
          <a href={withBase('ja/about/')} class="btn btn-primary">チーム全員のご紹介</a>
        </div>
      </div>
    </section>

  </main>

  <Footer
    brandTitle={copy.footer.brandTitle}
    brandTagline={copy.footer.brandTagline}
    exploreHeading={copy.footer.exploreHeading}
    exploreLinks={footerLinks}
    connectHeading={copy.footer.connectHeading}
    copyrightLine={copy.footer.copyrightLine}
    privacyHref={copy.footer.privacyHref}
    privacyLabel={copy.footer.privacyLabel}
    termsHref={copy.footer.termsHref}
    termsLabel={copy.footer.termsLabel}
    socialLinks={social.links}
  />
</BaseLayout>

<style>
  .portal-hero {
    padding: 8rem 1rem;
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, var(--color-bg-base) 100%);
    position: relative;
    overflow: hidden;
  }
  .portal-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 80%;
    height: 200%;
    background: radial-gradient(circle, rgba(66, 87, 166, 0.05) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
  }
  .portal-hero .container {
    position: relative;
    z-index: 1;
  }
  .portal-hero-title {
    font-size: clamp(3rem, 2rem + 4vw, 5rem);
    color: var(--color-text-heading);
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }
  .portal-hero-title strong {
    color: var(--color-primary);
  }
  .portal-hero-slogan {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 3rem;
  }
  .project-preview-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
    background: var(--color-bg-base);
    padding: 3rem;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0,0,0,0.03);
  }
  @media (min-width: 768px) {
    .project-preview-container {
      grid-template-columns: 1fr 1fr;
    }
  }
  .project-preview-text h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .project-preview-text p {
    font-size: 1.125rem;
    margin-bottom: 2rem;
    color: var(--color-text-main);
  }
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
    /* ---- Team blocks ---- */
  .team-blocks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 640px) {
    .team-blocks { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .team-blocks { grid-template-columns: repeat(3, 1fr); }
  }
  .team-block {
    background: var(--color-bg-base);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--border-radius-lg);
    padding: 1.75rem;
  }
  .team-block-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .team-block h3 {
    font-size: 1.125rem;
    color: var(--color-text-heading);
    margin: 0;
  }
  .team-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .team-tag.wet      { background: #dbeafe; color: #1e40af; }
  .team-tag.dry      { background: #dcfce7; color: #166534; }
  .team-tag.hp       { background: #fef9c3; color: #854d0e; }
  .team-tag.funding  { background: #fce7f3; color: #9d174d; }
  .team-tag.wiki     { background: #ede9fe; color: #5b21b6; }

  /* ---- Project preview tag ---- */
  .project-preview-tag {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.2rem 0.75rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ---- DNA graphic placeholder ---- */
  .dna-graphic-placeholder {
    background: var(--color-bg-alt);
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    min-height: 200px;
    color: var(--color-text-muted);
  }

  /* ---- Mission grid ---- */
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) {
    .mission-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .mission-card {
    background: var(--color-bg-base);
    border-radius: var(--border-radius-lg);
    padding: 2rem;
    text-align: center;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .mission-card .icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .mission-card h3 {
    font-size: 1.125rem;
    color: var(--color-text-heading);
    margin-bottom: 0.75rem;
  }
</style>
