---
/**
 * Activities Page (JA)
 */
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import Activities from '../../../components/Activities.astro';
import { withBase } from '../../../lib/paths';

const activities = (await getCollection('activities')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PageLayout
  title="活動 | iGEM Okinawa"
  description="iGEM Okinawa 2026年チームの活動一覧。ウェットラボ、ドライラボ、アウトリーチなど。"
  locale="ja"
>
  <PageHero
    title="チーム活動"
    subtitle="ウェットラボ実験からコンピュータモデリングまで、チームの取り組みをご覧ください。"
    breadcrumbs={[{ label: 'ホーム', href: withBase('ja/') }]}
  />

  <Activities
    locale="ja"
    sectionTitle="2026年のハイライト"
    subtitle="各チームの現在のプロジェクトと進行中の作業。"
    activities={activities}
  />
</PageLayout>
