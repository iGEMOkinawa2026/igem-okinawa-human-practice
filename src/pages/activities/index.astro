---
/**
 * Activities Page (EN) — Team-wide activities (Wet/Dry Lab, etc.)
 */
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Activities from '../../components/Activities.astro';
import { withBase } from '../../lib/paths';

const activities = (await getCollection('activities')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PageLayout
  title="Activities | iGEM Okinawa"
  description="Explore iGEM Okinawa's 2026 team activities including wet lab, dry lab, and outreach work."
  locale="en"
>
  <PageHero
    title="Team Activities"
    subtitle="What our team is working on — from wet lab experiments to computational modeling."
    breadcrumbs={[{ label: 'Home', href: withBase('') }]}
  />

  <Activities
    locale="en"
    sectionTitle="2026 Highlights"
    subtitle="Current projects and ongoing work across all teams."
    activities={activities}
  />
</PageLayout>
