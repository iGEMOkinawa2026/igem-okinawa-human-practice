---
/**
 * Portal Landing Page (EN)
 */
import YAML from 'yaml';

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { siteCopy } from '../data/siteCopy';
import { getMainNav } from '../data/navigation';
import { withBase } from '../lib/paths';
import { getEntry } from 'astro:content';
import { getSettings } from '../lib/settings';

import socialRaw from '../data/social.yaml?raw';

import { Image } from 'astro:assets';
import iconWet      from '../assets/icon-wet.png';
import iconDry      from '../assets/icon-dry.png';
import iconHp       from '../assets/icon-hp.png';
import iconFunding  from '../assets/icon-funding.png';
import iconWiki     from '../assets/icon-wiki.png';

const settings = getSettings();
const currentYear = settings.current_year;
const currentProject = await getEntry('project', currentYear.toString());


const social = YAML.parse(socialRaw) as {
  links: { platform: string; url: string; shortLabel?: string }[];
};

const copy = siteCopy.en;
const navItems = getMainNav('en');

const footerLinks = navItems.map((item) => ({
  label: item.label,
  href: item.href,
}));

---

<BaseLayout title={`Portal - ${copy.page.title}`} description="Welcome to the iGEM Okinawa Team Portal" lang="en">
  <Header
    siteTitle={copy.header.siteTitle}
    logoHref={withBase('')}
    navItems={navItems}
    enHref={withBase('')}
    jaHref={withBase('ja/')}
    activeLang="en"
    menuToggleLabel={copy.header.menuToggleLabel}
  />

  <main>
    <!-- Hero Section -->
    <section class="portal-hero">
      <div class="container text-center portal-hero-content">
        <div class="portal-hero-title-wrapper">
          <!-- left shisa -->
          <div class="portal-shisa portal-shisa-left" aria-hidden="true">
            <img src={withBase('shisa_left.PNG')} alt="" width="280" height="280" loading="eager" />
          </div>
          <h1 class="portal-hero-title">iGEM <strong>Okinawa</strong></h1>
          <!-- right shisa -->
          <div class="portal-shisa portal-shisa-right" aria-hidden="true">
            <img src={withBase('shisa_right.PNG')} alt="" width="280" height="280" loading="eager" />
          </div>
        </div>
        <p class="portal-hero-slogan">Creating the Future Through Synthetic Biology.</p>
        <div class="portal-hero-actions">
          <a href="#about" class="btn btn-primary btn-large">Discover Our Mission</a>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="section section-alt">
      <div class="container">
        <div class="section-header text-center">
          <h2>About iGEM Okinawa</h2>
          <p class="subtitle">Who we are</p>
        </div>
        <div class="mission-grid">
          <!-- card1: 実績 -->
          <div class="mission-card">
            <div class="icon">🏆</div>
            <h3>2025 Gold Medal</h3>
            <p>In our debut year at iGEM 2025, iGEM Okinawa earned a Gold Medal — a testament to the team's dedication to rigorous science and community engagement.</p>
          </div>
          <!-- card2: チーム構成 -->
          <div class="mission-card">
            <div class="icon">🏫</div>
            <h3>Multi-School Joint Team</h3>
            <p>We bring together students from OIST, NIT Okinawa College, and the University of the Ryukyus — combining diverse expertise across wet lab, dry lab, and human practice.</p>
          </div>
          <!-- card3: 地域課題 -->
          <div class="mission-card">
            <div class="icon">🌾</div>
            <h3>Local Challenges, Real Impact</h3>
            <p>Our projects are rooted in Okinawa's unique environment. We work directly with local farmers and communities to ensure our synthetic biology solutions address real, pressing needs.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- Project Preview -->
    <section class="section">
      <div class="container">
        {currentProject ? (
          <div class="project-preview-container">
            <div class="project-preview-text">
              <h2>Current Project: {currentYear}</h2>
              <p class="project-preview-tag">{currentProject.data.title}</p>
              <p>
                {currentProject.data.summary}
              </p>
              <a href={withBase(`archive/${currentYear}/`)} class="btn btn-primary">Read More</a>
            </div>
            <div class="project-preview-visual">
              {currentProject.data.image ? (
                <img src={withBase(currentProject.data.image)} alt={currentProject.data.title} style="width:100%; border-radius: var(--border-radius-md);" />
              ) : (
                <div class="dna-graphic-placeholder" style="background: var(--color-sub2, #6A9BD6); color: white; padding: 2rem; border-radius: var(--border-radius-md); text-align: center;">
                  🧬 {currentProject.data.title}
                </div>
              )}
            </div>
          </div>
        ) : (
          <div class="text-center">
            <p>Current project information is not available.</p>
          </div>
        )}
      </div>
    </section>

    <!-- Team Section -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-header text-center">
          <h2>Our Team</h2>
          <p class="subtitle">
            Students from OIST, NIT Okinawa College, and the University of the Ryukyus —
            united by synthetic biology.
          </p>
        </div>

        <div class="team-blocks">

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag wet">Wet</span>
              <h3>Wet Lab</h3>
              <Image src={iconWet} alt="" width={64} height={64} loading="lazy" class="team-block-icon" />
            </div>
            <p>Responsible for all experimental work — phage isolation, protein engineering, cloning, and lab validation of AI-predicted variants.</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag dry">Dry</span>
              <h3>Dry Lab</h3>
              <Image src={iconDry} alt="" width={64} height={64} loading="lazy" class="team-block-icon" />
            </div>
            <p>Builds and runs the AI-based pipeline for predicting low-pH resistant phage protein variants. Handles computational modeling and data analysis.</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag hp">Human Practice</span>
              <h3>Human Practice</h3>
              <Image src={iconHp} alt="" width={64} height={64} loading="lazy" class="team-block-icon" />
            </div>
            <p>Connects our science to society — engaging with local farmers, medical professionals, and communities to ensure our work addresses real needs.</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag funding">Funding</span>
              <h3>Funding</h3>
              <Image src={iconFunding} alt="" width={64} height={64} loading="lazy" class="team-block-icon" />
            </div>
            <p>Manages sponsorship outreach, donation campaigns, and financial planning to sustain our research and international competition entry.</p>
          </div>

          <div class="team-block">
            <div class="team-block-header">
              <span class="team-tag wiki">Wiki / Video</span>
              <h3>Wiki / Video</h3>
              <Image src={iconWiki} alt="" width={64} height={64} loading="lazy" class="team-block-icon" />
            </div>
            <p>Documents and communicates our research through the iGEM Wiki, promotional videos, and this website — making our work accessible to the world.</p>
          </div>

        </div>

        <div class="text-center" style="margin-top: 3rem;">
          <a href={withBase('about/')} class="btn btn-primary">Meet the Full Team</a>
        </div>
      </div>
    </section>

    <!-- Support / Donation CTA Section -->
    <section class="section support-cta">
      <div class="container text-center">
        <div class="support-cta-inner">
          <p class="support-cta-eyebrow">Support Us</p>
          <h2 class="support-cta-heading">Help Us Reach Paris 2026</h2>
          <p class="support-cta-body">
            iGEM Okinawa runs entirely on the passion of students and the generosity of our supporters.
            Your donation funds lab supplies, travel to the jamboree, and the next generation of Okinawan science.
          </p>
          <a href={withBase('support/')} class="btn btn-highlight btn-large">Support iGEM Okinawa →</a>
        </div>
      </div>
    </section>

<style>
  .portal-hero-title-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: clamp(0.5rem, 2vw, 2rem);
    margin-bottom: 1rem;
  }
  .portal-shisa {
    flex-shrink: 0;
    width: clamp(60px, 15vw, 160px);
  }
  .portal-shisa img {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 480px) {
    .portal-shisa { width: clamp(40px, 12vw, 60px); }
  }
  /* Team blocks */
  .team-blocks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 640px) {
    .team-blocks { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .team-blocks { grid-template-columns: repeat(3, 1fr); }
  }
  .team-block {
    position: relative;
    background: var(--color-bg-base);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--border-radius-lg);
    padding: 1.75rem;
    padding-right: 5.5rem;
  }
  .team-block-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .team-block-icon {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 60px;
    height: 60px;
    object-fit: contain;
    margin: 0;
  }
  .team-block h3 {
    font-size: 1.125rem;
    color: var(--color-text-heading);
    margin: 0;
  }
  .team-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  /* EDIT: チームカラーはここで変更 */
  .team-tag.wet      { background: #dbeafe; color: #1e40af; }
  .team-tag.dry      { background: #dcfce7; color: #166534; }
  .team-tag.hp       { background: #fef9c3; color: #854d0e; }
  .team-tag.funding  { background: #fce7f3; color: #9d174d; }
  .team-tag.wiki     { background: #ede9fe; color: #5b21b6; }
</style>

  </main>

  <Footer
    brandTitle={copy.footer.brandTitle}
    brandTagline={copy.footer.brandTagline}
    exploreHeading={copy.footer.exploreHeading}
    exploreLinks={footerLinks}
    connectHeading={copy.footer.connectHeading}
    copyrightLine={copy.footer.copyrightLine}
    privacyHref={copy.footer.privacyHref}
    privacyLabel={copy.footer.privacyLabel}
    termsHref={copy.footer.termsHref}
    termsLabel={copy.footer.termsLabel}
    socialLinks={social.links}
  />
</BaseLayout>

<style>
  .portal-hero {
    padding: 8rem 1rem;
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, var(--color-bg-base) 100%);
    position: relative;
    overflow: hidden;
  }
  .portal-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 80%;
    height: 200%;
    background: radial-gradient(circle, rgba(63, 209, 199, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
  }
  .portal-hero .container {
    position: relative;
    z-index: 1;
  }
  .portal-hero-title {
    font-size: clamp(3rem, 2rem + 4vw, 5rem);
    color: var(--color-text-heading);
    margin-bottom: 0;
    letter-spacing: -1px;
    line-height: 1.1;
  }
  .portal-hero-title strong {
    color: var(--color-primary);
  }
  .portal-hero-slogan {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 3rem;
  }
  .project-preview-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
    background: var(--color-bg-base);
    padding: 3rem;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0,0,0,0.03);
  }
  @media (min-width: 768px) {
    .project-preview-container {
      grid-template-columns: 1fr 1fr;
    }
  }
  .project-preview-text h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .project-preview-text p {
    font-size: 1.125rem;
    margin-bottom: 2rem;
    color: var(--color-text-main);
  }
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .support-cta {
  background: linear-gradient(135deg, var(--color-primary) 0%, #2fa198 100%);
  padding-block: clamp(3rem, 6vw, 6rem);
  }
  .support-cta-inner {
    max-width: 640px;
    margin-inline: auto;
  }
  .support-cta-eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.75rem;
  }
  .support-cta-heading {
    font-size: clamp(1.75rem, 2rem + 1vw, 2.75rem);
    color: #fff;
    margin-bottom: 1rem;
  }
  .support-cta-body {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    max-width: 56ch;
    margin-inline: auto;
  }
</style>
