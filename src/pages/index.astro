---
import { getCollection } from 'astro:content';
import YAML from 'yaml';

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Mission from '../components/Mission.astro';
import Activities from '../components/Activities.astro';
import Support from '../components/Support.astro';
import ArchivePreview from '../components/ArchivePreview.astro';
import Footer from '../components/Footer.astro';

import { homeCopy } from '../data/homeCopy';
import { withBase } from '../lib/paths';

import socialRaw from '../data/social.yaml?raw';

const social = YAML.parse(socialRaw) as {
  links: { platform: string; url: string; shortLabel?: string }[];
};

const copy = homeCopy.en;

const activities = (await getCollection('activities')).sort(
  (a, b) => a.data.order - b.data.order,
);
const sponsors = (await getCollection('sponsors')).sort(
  (a, b) => a.data.order - b.data.order,
);
const archiveEntries = (await getCollection('archive')).sort((a, b) => {
  if (b.data.year !== a.data.year) return b.data.year - a.data.year;
  return a.data.order - b.data.order;
});
---

<BaseLayout title={copy.page.title} description={copy.page.description} lang="en">
  <Header
    siteTitle={copy.header.siteTitle}
    logoHref="#"
    navItems={[...copy.header.nav]}
    enHref={withBase('')}
    jaHref={withBase('ja/')}
    activeLang="en"
    menuToggleLabel={copy.header.menuToggleLabel}
  />

  <main>
    <Hero
      badgeNatural={copy.hero.badgeNatural}
      badgeText={copy.hero.badgeText}
      headingPrefix={copy.hero.headingPrefix}
      headingStrong={copy.hero.headingStrong}
      headingSuffix={copy.hero.headingSuffix}
      lede={copy.hero.lede}
      primaryCtaLabel={copy.hero.primaryCtaLabel}
      primaryCtaHref={copy.hero.primaryCtaHref}
      secondaryCtaLabel={copy.hero.secondaryCtaLabel}
      secondaryCtaHref={copy.hero.secondaryCtaHref}
      imagePlaceholderText={copy.hero.imagePlaceholderText}
    />

    <About
      visualPlaceholder={copy.about.visualPlaceholder}
      title={copy.about.title}
      paragraphs={[...copy.about.paragraphs]}
    />

    <Mission
      sectionTitle={copy.mission.sectionTitle}
      subtitle={copy.mission.subtitle}
      cards={[...copy.mission.cards]}
    />

    <Activities
      locale="en"
      sectionTitle={copy.activitiesSection.sectionTitle}
      subtitle={copy.activitiesSection.subtitle}
      activities={activities}
    />

    <Support
      locale="en"
      title={copy.support.title}
      body={copy.support.body}
      sponsorCtaHref={copy.support.sponsorCtaHref}
      sponsorCtaLabel={copy.support.sponsorCtaLabel}
      deckHref={copy.support.deckHref}
      deckLabel={copy.support.deckLabel}
      sponsors={sponsors}
    />

    <ArchivePreview
      locale="en"
      title={copy.archive.title}
      body={copy.archive.body}
      archiveButtonLabel={copy.archive.archiveButtonLabel}
      entries={archiveEntries}
    />
  </main>

  <Footer
    brandTitle={copy.footer.brandTitle}
    brandTagline={copy.footer.brandTagline}
    exploreHeading={copy.footer.exploreHeading}
    exploreLinks={[...copy.footer.exploreLinks]}
    connectHeading={copy.footer.connectHeading}
    copyrightLine={copy.footer.copyrightLine}
    privacyHref={copy.footer.privacyHref}
    privacyLabel={copy.footer.privacyLabel}
    termsHref={copy.footer.termsHref}
    termsLabel={copy.footer.termsLabel}
    socialLinks={social.links}
  />
</BaseLayout>
