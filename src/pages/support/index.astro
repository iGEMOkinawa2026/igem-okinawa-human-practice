---
/**
 * Support / Sponsors Page (EN)
 */
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Support from '../../components/Support.astro';
import { withBase } from '../../lib/paths';

const sponsors = (await getCollection('sponsors')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PageLayout
  title="Support Us | iGEM Okinawa"
  description="Support iGEM Okinawa's mission. Learn about sponsorship opportunities and how to help."
  locale="en"
>
  <PageHero
    title="Support Us"
    subtitle="Your support directly funds our lab equipment, project development, and competition entry."
    breadcrumbs={[{ label: 'Home', href: withBase('') }]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="support-info-grid">
        <div class="info-card">
          <h3>Participating Institutions</h3>
          <ul>
            <li>National Institute of Technology, Okinawa College (KOSEN)</li>
            <li>Okinawa Institute of Science and Technology Graduate University (OIST)</li>
            <li>University of the Ryukyus (Ryudai)</li>
          </ul>
        </div>
        <div class="info-card">
          <h3>Required Funding</h3>
          <ul>
            <li><strong>Team registration fee:</strong> €8,700 EUR</li>
            <li><strong>Participation fee:</strong> €575 EUR per person</li>
            <li><strong>Additional costs:</strong> travel, accommodation, lab materials, outreach activities</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section text-center">
    <div class="container">
      <h2>Make a Donation</h2>
      <p style="margin-bottom: 2rem;">We accept donations via Bank Transfer and Credit Card.</p>
      
      <div class="payment-methods" style="display: flex; justify-content: center; gap: 2rem; margin-bottom: 2rem; flex-wrap: wrap;">
        <div class="payment-method-card" style="padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--border-radius-md); flex: 1; min-width: 250px;">
          <h4>🏦 Bank Transfer</h4>
          <p>You can donate directly to our official bank account.</p>
        </div>
        <div class="payment-method-card" style="padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--border-radius-md); flex: 1; min-width: 250px;">
          <h4>💳 Credit Card</h4>
          <p>We process credit card donations securely via OIST forms.</p>
        </div>
      </div>

      <a href="https://forms.oist.jp/form/donate-now" target="_blank" rel="noopener noreferrer" class="btn btn-highlight btn-large">Donate Now</a>
    </div>
  </section>

  <Support
    locale="en"
    title="Empower the Next Generation of Scientists"
    body="iGEM Okinawa's journey is made possible by the generosity of our sponsors and community. Your support directly funds our lab equipment, project development, and entry into the international iGEM competition."
    sponsorCtaHref="mailto:contact@igem-okinawa.jp"
    sponsorCtaLabel="Become a Sponsor"
    deckHref="#"
    deckLabel="Sponsorship deck coming soon"
    sponsors={sponsors}
  />
</PageLayout>

<style>
  .support-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .support-info-grid { grid-template-columns: 1fr 1fr; }
  }
  .info-card {
    background: var(--color-bg-base);
    padding: 2rem;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-sm);
  }
  .info-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .info-card ul {
    list-style-type: disc;
    padding-left: 1.5rem;
  }
  .info-card li {
    margin-bottom: 0.5rem;
  }
</style>
