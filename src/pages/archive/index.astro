---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Archive | iGEM Okinawa"
  description="Past activities, projects, and teams from iGEM Okinawa."
>
  <main class="section container">
    <h1 style="font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 1rem;">
      Archive
    </h1>
    <p style="color: var(--color-text-muted); max-width: 40rem;">
      This page is a placeholder for the full archive. Replace it with your historical content when ready.
    </p>
    <p style="margin-top: 1.5rem;">
      <a href={import.meta.env.BASE_URL} class="btn btn-outline-dark">Back to home</a>
    </p>
  </main>
</BaseLayout>
