---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { siteCopy } from '../../data/siteCopy';
import { getMainNav } from '../../data/navigation';
import { withBase } from '../../lib/paths';
import YAML from 'yaml';
import socialRaw from '../../data/social.yaml?raw';

const members = (await getCollection('members')).sort((a, b) => a.data.order - b.data.order);
const leaders = members.filter(m => m.data.is_leader);
const others = members.filter(m => !m.data.is_leader);

const renderTags = (member: any) => {
  let tags: string[] = [];
  if (member.data.roles && member.data.roles.length > 0) {
    tags = member.data.roles;
  } else if (member.data.team) {
    tags = [member.data.team];
  }
  return tags.map((t: string) => `<span class="team-tag ${t.replace(' ', '-')}">${t}</span>`).join(' ');
};

const social = YAML.parse(socialRaw) as any;
const copy = siteCopy.en;
const navItems = getMainNav('en');
const footerLinks = navItems.map(i => ({ label: i.label, href: i.href }));
---

<BaseLayout title={`Team - ${copy.page.title}`} description="Meet the iGEM Okinawa team" lang="en">
  <Header
    siteTitle={copy.header.siteTitle}
    logoHref={withBase('')}
    navItems={navItems}
    enHref={withBase('team/')}
    jaHref={withBase('ja/team/')}
    activeLang="en"
    menuToggleLabel={copy.header.menuToggleLabel}
  />
  <main class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <h1 style="color: var(--color-primary);">Our Team</h1>
        <p class="subtitle">Students from across Okinawa working together.</p>
      </div>

      {[ 
        { title: 'Leadership', members: leaders, color: 'var(--color-bg-alt)', text: 'var(--color-primary)' },
        { title: 'Members', members: others, color: 'var(--color-bg-base)', text: 'var(--color-text-main)' }
      ].map(group => group.members.length > 0 && (
        <div style="margin-bottom: 4rem;">
          <h2 style={`display: inline-block; padding: 0.5rem 1rem; border-radius: var(--border-radius-md); background: ${group.color}; color: ${group.text}; margin-bottom: 1.5rem; border: 1px solid rgba(0,0,0,0.05);`}>
            {group.title}
          </h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem;">
            {group.members.map(member => (
              <div class="card" style="padding: 1.5rem; text-align: center; background: white; border-radius: var(--border-radius-lg); box-shadow: var(--shadow-sm);">
                <div style="width: 100px; height: 100px; border-radius: 50%; background: var(--color-bg-alt); margin: 0 auto 1rem; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                  {member.data.image ? (
                    <img src={withBase(member.data.image)} alt={member.data.name} style="width: 100%; height: 100%; object-fit: cover;" />
                  ) : (
                    <span style="font-size: 2rem; color: var(--color-text-muted);">👤</span>
                  )}
                </div>
                <h3 style="margin-bottom: 0.5rem; color: var(--color-text-heading);">{member.data.name}</h3>
                {member.data.role && <p style="font-weight: 600; color: var(--color-primary); font-size: 0.9rem; margin-bottom: 0.5rem;">{member.data.role}</p>}
                {member.data.institution && <p style="font-size: 0.85rem; color: var(--color-text-main); margin-bottom: 0.5rem;">{member.data.institution}</p>}
                <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; margin-top: 0.75rem;" set:html={renderTags(member)}></div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer brandTitle={copy.footer.brandTitle} brandTagline={copy.footer.brandTagline} exploreHeading={copy.footer.exploreHeading} exploreLinks={footerLinks} connectHeading={copy.footer.connectHeading} copyrightLine={copy.footer.copyrightLine} privacyHref={copy.footer.privacyHref} privacyLabel={copy.footer.privacyLabel} termsHref={copy.footer.termsHref} termsLabel={copy.footer.termsLabel} socialLinks={social.links} />
</BaseLayout>

<style>
  .team-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .team-tag.wet      { background: #dbeafe; color: #1e40af; }
  .team-tag.dry      { background: #dcfce7; color: #166534; }
  .team-tag.human-practice { background: #fef9c3; color: #854d0e; }
  .team-tag.funding  { background: #fce7f3; color: #9d174d; }
  .team-tag.wiki-video { background: #ede9fe; color: #5b21b6; }
  .team-tag.leader   { background: #fee2e2; color: #b91c1c; }
  .team-tag.advisor  { background: #e0e7ff; color: #4338ca; }
</style>
