---
/**
 * About Page (EN)
 * Team introduction + mission + members list
 */
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { withBase } from '../../lib/paths';
---

<PageLayout
  title="About Us | iGEM Okinawa"
  description="Learn about iGEM Okinawa — our team, mission, and history."
  locale="en"
>
  <PageHero
    title="About Us"
    subtitle="Who we are and what drives our pursuit of science."
    breadcrumbs={[{ label: 'Home', href: withBase('') }]}
  />

  <section class="section">
    <div class="container about-page-content">
      <!-- What is iGEM Okinawa -->
      <div class="about-section">
        <h2>What is iGEM Okinawa?</h2>
        <p>
          iGEM Okinawa is a collective of passionate students from various disciplines, united by a shared
          vision: to advance synthetic biology and apply it to real-world problems.
        </p>
        <p>
          Originating from the unique island environment of Okinawa, we aim to bridge local ecological
          wisdom with global scientific innovation. Our multidisciplinary approach means we tackle problems
          ranging from environmental conservation to finding novel biotechnological applications.
        </p>
      </div>

      <!-- What is iGEM? -->
      <div class="about-section">
        <h2>What is iGEM?</h2>
        <p>iGEM (International Genetically Engineered Machine) is the world's premier synthetic biology competition. Originally starting at MIT, it now brings together undergraduate, graduate, and high school students from across the globe.</p>
        <p>Teams are evaluated not just on their scientific projects, but also on their presentations, wiki documentation, and human practices — how they integrate their work with society.</p>
      </div>

      <!-- What is Synthetic Biology? -->
      <div class="about-section">
        <h2>What is Synthetic Biology?</h2>
        <p>Synthetic biology is an interdisciplinary branch of science that combines biology and engineering. It involves the design and construction of new biological entities such as enzymes, genetic circuits, and cells, or the redesign of existing biological systems.</p>
        <p>This powerful technology holds immense potential to solve critical challenges across various fields, including medicine, agriculture, and environmental sustainability.</p>
      </div>

      <!-- Our Solution -->
      <div class="about-section">
        <h2>Our Solution (2026 Project)</h2>
        <p>For our 2026 project, we are developing an AI platform designed to engineer low-pH resistant bacteriophages. These specialized phages are targeted against severe pathogens such as <em>Salmonella</em>, <em>ETEC</em>, and <em>H. pylori</em>.</p>
        <p>By leveraging synthetic biology, we aim to provide a novel approach to the growing problem of Antimicrobial Resistance (AMR), offering effective alternatives to traditional antibiotics.</p>
      </div>

      <!-- How Are iGEM Teams Judged? -->
      <div class="about-section">
        <h2>How Are iGEM Teams Judged?</h2>
        <p>iGEM teams are evaluated based on a comprehensive set of medal criteria, which determine whether a team earns a Bronze, Silver, or Gold medal. Success requires excelling in multiple areas, including engineering success, contribution to the community, and comprehensive human practices.</p>
        <p>In addition to medals, teams compete for Special Awards (such as Best Project, Best Wiki, etc.). A team's Wiki and Presentation are critical components of the judging process, serving as the primary ways teams communicate their work to the judges and the world.</p>
      </div>
    </div>
  </section>
</PageLayout>
